{
  "name": "@vn-gis/map",
  "version": "2.1.0",
  "description": "Lightweight library for rendering Vietnam maps with Leaflet and MapLibre GL JS support",
  "keywords": [
    "vietnam",
    "map",
    "gis",
    "geojson",
    "provinces",
    "leaflet",
    "maplibre"
  ],
  "license": "MIT",
  "author": "vn-gis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/github-nqvnlc/vn-gis-map.git"
  },
  "bugs": {
    "url": "https://github.com/github-nqvnlc/vn-gis-map/issues"
  },
  "homepage": "https://github.com/github-nqvnlc/vn-gis-map#readme",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./leaflet": {
      "types": "./dist/renderers/leaflet.d.ts",
      "import": "./dist/renderers/leaflet.esm.js",
      "require": "./dist/renderers/leaflet.cjs.js"
    },
    "./maplibre": {
      "types": "./dist/renderers/maplibre.d.ts",
      "import": "./dist/renderers/maplibre.esm.js",
      "require": "./dist/renderers/maplibre.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true
  },
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "build:watch": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs/api src/index.ts",
    "clean": "rimraf dist docs/api",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "leaflet": "^1.9.0",
    "maplibre-gl": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.16",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jsdom": "^26.1.0",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.5.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.31.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
